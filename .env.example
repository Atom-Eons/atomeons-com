# --- Required for production ---
# Stripe (live or test keys; same vars)
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Token signing secret (HMAC SHA-256). Generate: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=replace_with_64_hex_chars

# The Vercel Blob (or any HTTPS) URL of the product ZIP.
# Upload via `vercel blob put` and paste the resulting URL here.
PRODUCT_BLOB_URL=https://....public.blob.vercel-storage.com/orangebox-v1.zip

# Public site URL (used to build download links inside the webhook)
NEXT_PUBLIC_SITE_URL=https://atomeons.com

# --- Email delivery: pick ONE provider ---
# Option A: Loops (recommended; already in stack)
LOOPS_API_KEY=
LOOPS_TRANSACTIONAL_ID=

# Option B: Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=ORANGEBOX <orders@atomeons.com>

# If neither is set, the webhook still records the order but cannot send
# the download link. The buyer's success page tells them to email us.

# --- X (Twitter) Ads conversion tracking (optional) ---
# From ads.x.com → Tools → Conversion Tracking
# Pixel base code id: a 5-7 char base36 string like "ofhrn"
NEXT_PUBLIC_X_PIXEL_ID=
# Specific conversion event id for the $49 purchase: a 7-char base36 string
NEXT_PUBLIC_X_EVENT_ID=
# When unset, the pixel + event scripts no-op (no requests fire).
